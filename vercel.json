{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/vercel_app.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "backend/vercel_app.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/vercel_app.py"
    }
  ]
}
