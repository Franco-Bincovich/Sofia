# ─────────────────────────────────────────────────────────────────────────────
#  HR Karstec — Variables de entorno
#  Copiar este archivo a .env y completar los valores reales.
#  NUNCA commitear .env al repositorio — está en .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── APLICACIÓN ────────────────────────────────────────────────────────────────
# Valores posibles: development | staging | production
# En producción: desactiva /docs de FastAPI y activa logs JSON.
APP_ENV=development


# ── SUPABASE ──────────────────────────────────────────────────────────────────
# Proyecto → Settings → API en app.supabase.com
#
# [BACKEND] URL del proyecto y claves de API:
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSJ9.XXXXX
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSJ9.XXXXX

# [FRONTEND] Prefijo NEXT_PUBLIC_ obligatorio para exponer al cliente.
# Usar los mismos valores que SUPABASE_URL y SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSJ9.XXXXX


# ── AUTH ──────────────────────────────────────────────────────────────────────
# [BACKEND] Secreto para firmar los JWT internos (≠ JWT de Supabase).
# Mínimo 32 caracteres aleatorios. Generar con:
#   openssl rand -hex 32
JWT_SECRET=reemplazar-con-secreto-aleatorio-de-minimo-32-caracteres
JWT_EXPIRATION_MINUTES=60
REFRESH_TOKEN_EXPIRATION_DAYS=30


# ── ANTHROPIC ─────────────────────────────────────────────────────────────────
# [BACKEND] API key para el motor de IA HR Karstec.
# Obtener en: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXX


# ── RESEND ────────────────────────────────────────────────────────────────────
# [BACKEND] API key para envío de emails transaccionales (assessments, notif.).
# Obtener en: resend.com → API Keys
RESEND_API_KEY=re_XXXXXXXXXXXXX
RESEND_FROM_EMAIL=noreply@hrkarstec.com


# ── CORS ──────────────────────────────────────────────────────────────────────
# [BACKEND] URLs del frontend autorizadas, separadas por coma.
# Desarrollo:  http://localhost:3000
# Producción:  https://hrkarstec.vercel.app
ALLOWED_ORIGINS=http://localhost:3000


# ── FRONTEND ──────────────────────────────────────────────────────────────────
# [FRONTEND] URL base del backend para llamadas a la API.
# Desarrollo:  http://localhost:8000
# Producción:  https://hrkarstec.vercel.app  (si está en el mismo dominio via /api)
NEXT_PUBLIC_API_URL=http://localhost:8000
